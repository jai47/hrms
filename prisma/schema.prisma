generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Employee {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId   String   @unique
  firstName    String
  lastName     String
  email        String   @unique
  password     String
  phone        String?
  dateOfBirth  DateTime?
  gender       Gender?
  address      String?
  departmentId String?  @db.ObjectId
  department   Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  position     String
  hireDate     DateTime @default(now())
  employmentStatus EmploymentStatus @default(ACTIVE)
  salary       Float?
  bankAccount  String?
  emergencyContact String?
  emergencyPhone String?
  profileImage String?
  biometricId  String?  @unique
  role         Role     @default(EMPLOYEE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendances       Attendance[]
  performances      Performance[]       @relation("EmployeePerformance")
  reviewedPerformances Performance[]    @relation("ReviewerPerformance")
  leaveRequests     LeaveRequest[]
  documents         Document[]
  notifications     Notification[]
  shifts            ShiftAssignment[]
  managedDepartments Department[]       @relation("DepartmentManager")
  biometricLogs     BiometricLog[]
  projectsLed       Project[]         @relation("ProjectLead")
  projectMemberships ProjectMember[]
  assignedIssues    Issue[]           @relation("AssignedIssues")
  reportedIssues    Issue[]           @relation("ReportedIssues")
  issueComments     IssueComment[]
  timeEntries       TimeEntry[]
  paySlips          PaySlip[]
  dailyWorkLogs     DailyWorkLog[]

  @@map("employees")
}

model Department {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  managerId   String?  @db.ObjectId
  manager     Employee? @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[] @relation("DepartmentEmployees")
  shifts    Shift[]

  @@map("departments")
}

model Shift {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  startTime   String
  endTime     String
  breakMinutes Int     @default(60)
  workingDays String   // JSON array of days: ["MON", "TUE", ...]
  departmentId String? @db.ObjectId
  department  Department? @relation(fields: [departmentId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ShiftAssignment[]

  @@map("shifts")
}

model ShiftAssignment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId String   @db.ObjectId
  employee  Employee @relation(fields: [employeeId], references: [id])
  shiftId   String   @db.ObjectId
  shift     Shift    @relation(fields: [shiftId], references: [id])
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime @default(now())

  @@unique([employeeId, shiftId, startDate])
  @@map("shift_assignments")
}

model Attendance {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  employeeId   String           @db.ObjectId
  employee     Employee         @relation(fields: [employeeId], references: [id])
  date         DateTime         @db.Date
  checkIn      DateTime?
  checkOut     DateTime?
  totalHours   Float?
  breakMinutes Int              @default(0)
  status       AttendanceStatus @default(ABSENT)
  source       AttendanceSource @default(MANUAL)
  deviceId     String?
  location     String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendances")
}

model LeaveRequest {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  employeeId  String        @db.ObjectId
  employee    Employee      @relation(fields: [employeeId], references: [id])
  leaveType   LeaveType
  startDate   DateTime      @db.Date
  endDate     DateTime      @db.Date
  totalDays   Float
  reason      String
  status      LeaveStatus   @default(PENDING)
  approvedBy  String?       @db.ObjectId
  approvedAt  DateTime?
  rejectedReason String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("leave_requests")
}

model Performance {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  employeeId  String            @db.ObjectId
  employee    Employee          @relation("EmployeePerformance", fields: [employeeId], references: [id])
  reviewPeriod String           // e.g., "2024-Q1", "2024-H1"
  reviewDate  DateTime          @db.Date
  reviewerId  String            @db.ObjectId
  reviewer    Employee          @relation("ReviewerPerformance", fields: [reviewerId], references: [id])
  overallRating Rating          @default(MEETS_EXPECTATIONS)
  goals       String?           // JSON string for goals
  achievements String?          // JSON string
  strengths   String?
  improvements String?
  comments    String?
  status      PerformanceStatus @default(DRAFT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  kpis        KPI[]

  @@map("performances")
}

model KPI {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  performanceId String   @db.ObjectId
  performance   Performance @relation(fields: [performanceId], references: [id])
  name          String
  target        Float
  actual        Float
  weight        Float    @default(1)
  rating        Rating
  createdAt     DateTime @default(now())

  @@map("kpis")
}

model Document {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  employeeId  String        @db.ObjectId
  employee    Employee      @relation(fields: [employeeId], references: [id])
  type        DocumentType
  title       String
  fileUrl     String
  expiryDate  DateTime?     @db.Date
  status      DocumentStatus @default(ACTIVE)
  uploadedAt  DateTime      @default(now())

  @@map("documents")
}

model Notification {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  employeeId String             @db.ObjectId
  employee  Employee            @relation(fields: [employeeId], references: [id])
  title     String
  message   String
  type      NotificationType
  isRead    Boolean             @default(false)
  link      String?
  createdAt DateTime            @default(now())

  @@index([employeeId, isRead])
  @@map("notifications")
}

model DailyWorkLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId  String   @db.ObjectId
  employee    Employee @relation(fields: [employeeId], references: [id])
  date        DateTime @db.Date
  summary     String
  tasksDone   String?
  blockers    String?
  nextSteps   String?
  hoursWorked Float?
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@map("daily_work_logs")
}

model BiometricDevice {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  deviceId      String              @unique
  name          String
  deviceType    BiometricDeviceType @default(ZK_DEVICE)
  location      String?
  ipAddress     String?
  port          Int?
  googleFormUrl String?
  webhookSecret String?
  isActive      Boolean             @default(true)
  lastSync      DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  logs        BiometricLog[]

  @@map("biometric_devices")
}

model BiometricLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  deviceId    String   @db.ObjectId
  device      BiometricDevice @relation(fields: [deviceId], references: [id])
  employeeId  String?  @db.ObjectId
  employee    Employee? @relation(fields: [employeeId], references: [id])
  biometricId String
  timestamp   DateTime
  eventType   BiometricEventType
  rawData     String?  // Raw data from device
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([deviceId, timestamp])
  @@index([employeeId, timestamp])
  @@map("biometric_logs")
}

model Settings {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  key               String   @unique
  value             String
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("settings")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
  PROBATION
}

enum Role {
  ADMIN
  HR_MANAGER
  MANAGER
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_LEAVE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
  REMOTE
}

enum LeaveType {
  ANNUAL
  SICK
  CASUAL
  MATERNITY
  PATERNITY
  EMERGENCY
  UNPAID
  COMPENSATORY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum Rating {
  EXCEEDS_EXPECTATIONS
  MEETS_EXPECTATIONS
  BELOW_EXPECTATIONS
  NEEDS_IMPROVEMENT
}

enum PerformanceStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
  FINALIZED
}

enum DocumentType {
  CONTRACT
  ID_DOCUMENT
  CERTIFICATE
  MEDICAL
  TAX_DOCUMENT
  OTHER
}

enum DocumentStatus {
  ACTIVE
  EXPIRED
  PENDING_RENEWAL
  ARCHIVED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  LEAVE_REQUEST
  LEAVE_APPROVED
  LEAVE_REJECTED
  PERFORMANCE_REVIEW
  ATTENDANCE_ALERT
  WORK_LOG_REMINDER
  DOCUMENT_EXPIRY
  ISSUE_ASSIGNED
  SYSTEM
}

enum BiometricDeviceType {
  ZK_DEVICE
  GOOGLE_FORM
}

enum BiometricEventType {
  CHECK_IN
  CHECK_OUT
  BREAK_START
  BREAK_END
  UNKNOWN
}

enum AttendanceSource {
  MANUAL
  BIOMETRIC
  GOOGLE_FORM
  FACE_RECOGNITION
  MOBILE_APP
  WEB_PORTAL
}

model Project {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  key         String        @unique
  name        String
  description String?
  leadId      String?       @db.ObjectId
  lead        Employee?     @relation("ProjectLead", fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  issues  Issue[]
  members ProjectMember[]
  sprints Sprint[]

  @@map("projects")
}

model ProjectMember {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  projectId  String      @db.ObjectId
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String      @db.ObjectId
  employee   Employee    @relation(fields: [employeeId], references: [id])
  role       ProjectRole @default(MEMBER)
  createdAt  DateTime    @default(now())

  @@unique([projectId, employeeId])
  @@map("project_members")
}

model Issue {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  projectId      String        @db.ObjectId
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issueNumber    Int
  title          String
  description    String?
  type           IssueType     @default(TASK)
  status         IssueStatus   @default(TODO)
  priority       IssuePriority @default(MEDIUM)
  assigneeId     String?       @db.ObjectId
  assignee       Employee?     @relation("AssignedIssues", fields: [assigneeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reporterId     String        @db.ObjectId
  reporter       Employee      @relation("ReportedIssues", fields: [reporterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dueDate        DateTime?     @db.Date
  estimatedHours Float?
  sprintId       String?       @db.ObjectId
  sprint         Sprint?       @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  comments    IssueComment[]
  timeEntries TimeEntry[]

  @@unique([projectId, issueNumber])
  @@index([assigneeId])
  @@index([status])
  @@index([sprintId])
  @@map("issues")
}

model Sprint {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  projectId String       @db.ObjectId
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  goal      String?
  startDate DateTime     @db.Date
  endDate   DateTime     @db.Date
  status    SprintStatus @default(PLANNED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  issues Issue[]

  @@index([projectId])
  @@map("sprints")
}

model IssueComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  issueId   String   @db.ObjectId
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId  String   @db.ObjectId
  author    Employee @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("issue_comments")
}

model TimeEntry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  issueId     String?  @db.ObjectId
  issue       Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)
  employeeId  String   @db.ObjectId
  employee    Employee @relation(fields: [employeeId], references: [id])
  date        DateTime @db.Date
  hours       Float
  description String?
  createdAt   DateTime @default(now())

  @@index([employeeId, date])
  @@index([issueId])
  @@map("time_entries")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum ProjectRole {
  LEAD
  MEMBER
  VIEWER
}

enum IssueType {
  TASK
  BUG
  STORY
  EPIC
}

enum IssueStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum IssuePriority {
  LOWEST
  LOW
  MEDIUM
  HIGH
  HIGHEST
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

model PaySlip {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  employeeId      String         @db.ObjectId
  employee        Employee       @relation(fields: [employeeId], references: [id])
  periodMonth     Int
  periodYear      Int
  baseSalary      Float
  workingDays     Int
  paidDays        Float
  presentDays     Float
  halfDays        Float
  absentDays      Float
  paidLeaveDays   Float
  unpaidLeaveDays Float
  lateDays        Int
  grossPay        Float
  deductions      Float
  netPay          Float
  status          PaySlipStatus  @default(DRAFT)
  breakdown       String
  generatedAt     DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([employeeId, periodMonth, periodYear])
  @@index([periodYear, periodMonth])
  @@map("payslips")
}

enum PaySlipStatus {
  DRAFT
  FINALIZED
  PAID
}